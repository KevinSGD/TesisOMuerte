# Copiá este archivo a ".env" en esta misma carpeta (junto a manage.py).
# No subas .env a Git: ya está en .gitignore.
#
# EQUIPO: Git NO incluye .env. Sin estas variables, Django usa SQLite en CADA PC
# y los horarios / tablas NO se guardan en Supabase ni los ve tu compañero.
# Pasá el .env por un canal privado o que cada uno copie host y contraseña del mismo proyecto.

DJANGO_SECRET_KEY=cambia-esto-en-produccion-o-usa-una-clave-larga-aleatoria

# Supabase / Postgres (Settings → Database → Connection parameters)
# HOST = solo el hostname, sin :puerto ni /postgres
DB_HOST=db.tu-proyecto-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu-contraseña-de-base

# Opcional (por defecto ya está bien para Supabase)
# DB_ENGINE=django.db.backends.postgresql
# DB_SSLMODE=require
