# 1) Copiá este archivo como ".env" en la carpeta donde está manage.py
#    (proyecto/horarios_universidad/.env)
# 2) Completá DB_HOST y DB_PASSWORD desde Supabase → Settings → Database
# 3) Probar:  python manage.py check_online_db
# 4) Tablas:  python manage.py migrate
#
# Git NO sube .env. Sin DB_HOST, Django usa SQLite local y NADA va a Supabase.

DJANGO_SECRET_KEY=cambia-esto-en-produccion-o-usa-una-clave-larga-aleatoria

# Sin espacios alrededor del "=". HOST = solo el hostname (ej. db.abc123.supabase.co)
DB_HOST=db.tu-proyecto-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu-contraseña-de-base

# DB_ENGINE=django.db.backends.postgresql
# DB_SSLMODE=require
