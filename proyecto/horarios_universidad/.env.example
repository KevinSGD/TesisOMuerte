# =============================================================
# GestorAulas — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA hagas commit del archivo .env con credenciales reales.
# =============================================================

# ─── Opción A: URL completa (tiene prioridad sobre las variables individuales)
# DATABASE_URL=postgresql+psycopg2://usuario:contraseña@host:5432/postgres?sslmode=require

# ─── Opción B: Variables individuales (Supabase / PostgreSQL)
# Pooler (recomendado para conexiones frecuentes):
DB_HOST=aws-0-us-west-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.tu-project-ref
DB_PASSWORD=tu-contraseña-aqui
DB_SSLMODE=require

# Conexión directa (para migraciones / acceso admin):
# DB_HOST=db.tu-project-ref.supabase.co
# DB_USER=postgres

# ─── Railway (opcional): delega el solver a un servicio remoto
# RAILWAY_RUN_URL=https://tu-servicio.railway.app/api/run
