# Variables de entorno opcionales para conexión a base de datos.
# Copiá este archivo como ".env" y completa valores según tu proveedor cloud.
# Sin espacios alrededor de "=".
DB_HOST=db.tu-proyecto-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu-contraseña-de-base
DB_SSLMODE=require

# Opcional: URL del servicio que ejecuta el algoritmo en Railway.
# Si la API corre dentro de Railway, puede ser una URL interna como:
# RAILWAY_RUN_URL=http://tesisomuerte.railway.internal/run
# Si corre en tu PC, usa la URL pública HTTPS del servicio.
# RAILWAY_RUN_URL=https://tu-servicio-railway.up.railway.app/run
